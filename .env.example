# ================================================
# FINANZA BANKING APP — ENVIRONMENT VARIABLES
# ================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it contains secrets!
# ================================================

# ========== DATABASE (Supabase PostgreSQL) ==========
# Primary connection string (async, for the app)
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Supabase project settings
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# Postgres credentials (used by Alembic migrations)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=YOUR_PASSWORD
POSTGRES_HOST=db.YOUR_PROJECT.supabase.co
POSTGRES_DATABASE=postgres

# Pooled connection (recommended for app connections)
POSTGRES_URL=postgres://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true
POSTGRES_URL_NON_POOLING=postgres://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require

# ========== SECURITY ==========
# CRITICAL: Change this to a long random string in production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING_IN_PRODUCTION

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ========== ENVIRONMENT ==========
ENVIRONMENT=development
# Valid values: development | staging | production

# API public URL (used for CORS and email links)
API_URL=https://yourdomain.com

# ========== ADMIN CREDENTIALS ==========
# Default super admin account (created on first startup)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=CHANGE_ME_BEFORE_PRODUCTION

# Role-based admin accounts
ADMIN_SUPER_ADMIN_EMAIL=admin@yourdomain.com
ADMIN_SUPER_ADMIN_PASSWORD=CHANGE_ME_BEFORE_PRODUCTION
ADMIN_ADMIN_EMAIL=admin@finanza.com
ADMIN_ADMIN_PASSWORD=CHANGE_ME_BEFORE_PRODUCTION
ADMIN_TREASURY_EMAIL=treasury@finanza.com
ADMIN_TREASURY_PASSWORD=CHANGE_ME_BEFORE_PRODUCTION
ADMIN_COMPLIANCE_EMAIL=compliance@finanza.com
ADMIN_COMPLIANCE_PASSWORD=CHANGE_ME_BEFORE_PRODUCTION
ADMIN_SUPPORT_EMAIL=support@finanza.com
ADMIN_SUPPORT_PASSWORD=CHANGE_ME_BEFORE_PRODUCTION

# ========== EMAIL — Gmail SMTP ==========
# Use a Gmail App Password (not your real password)
# Guide: https://support.google.com/accounts/answer/185833
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password_here
MAIL_FROM=your_email@gmail.com
MAIL_FROM_NAME=Finanza Bank
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=True
MAIL_SSL_TLS=False

# Email provider (gmail | ses)
EMAIL_PROVIDER=gmail

# ========== AWS (Optional — for SES email + S3 + Lambda) ==========
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_SENDER_EMAIL=noreply@yourdomain.com
SES_SENDER_NAME=Finanza Bank

# ========== REDIS (Optional — for price caching) ==========
# Set to your Redis server URL (defaults to localhost if not set)
REDIS_URL=redis://localhost:6379

# ========== EXTERNAL PAYMENT RAILS ==========
# Payrail Developer Console API
PAYRAIL_API_URL=https://payrail-rbb59a.fly.dev
PAYRAIL_API_KEY=your_payrail_api_key_here

# ========== FOREX API (Optional) ==========
# Register at https://fixer.io for live exchange rates
FIXER_IO_API_KEY=

# ========== CORS ALLOWED ORIGINS ==========
# Comma-separated list of allowed frontend origins
# Example: https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ========== WEBHOOK SECRETS (Optional) ==========
STRIPE_WEBHOOK_SECRET=
PAYSTACK_WEBHOOK_SECRET=
KYC_WEBHOOK_SECRET=

# ========== AWS ADVANCED (Optional) ==========
SNS_TOPIC_ARN=
SQS_PAYMENT_QUEUE_URL=
LAMBDA_KYC_PROCESSOR=
LAMBDA_FRAUD_DETECTOR=
S3_BUCKET_NAME=
ELASTICACHE_ENDPOINT=
